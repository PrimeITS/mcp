{
  "name": "@adamhancock/smileback-mcp",
  "version": "0.1.0",
  "description": "MCP server for SmileBack API integration with resource owner password authentication",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "smileback-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector tsx --env-file=.env src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "smileback",
    "api",
    "reviews",
    "customer-feedback",
    "nps",
    "csat"
  ],
  "author": "Adam Hancock",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
