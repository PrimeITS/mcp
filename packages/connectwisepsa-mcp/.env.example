# ConnectWise PSA API Configuration
# Note: The /v4_6_release/apis/3.0 path will be automatically appended if not present
CONNECTWISE_PSA_API_URL=https://your-instance.connectwise.com
CONNECTWISE_PSA_COMPANY_ID=your_company_id
CONNECTWISE_PSA_PUBLIC_KEY=your_public_key
CONNECTWISE_PSA_PRIVATE_KEY=your_private_key
# https://developer.connectwise.com/ClientID -  a clientId is required for all API calls to ConnectWise PSA. 
CONNECTWISE_PSA_CLIENT_ID=your_client_id